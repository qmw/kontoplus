const pakiety = [
  {
    name: "Start",
    price: "299",
    desc: "Dla jednoosobowych działalności i małych firm",
    featured: false,
    items: [
      "Do 30 dokumentów / miesiąc",
      "KPiR lub ryczałt",
      "Deklaracje VAT",
      "Pliki JPK",
      "Kontakt e-mail",
      "Raport kwartalny",
    ],
    excluded: ["Obsługa kadrowa", "Doradztwo podatkowe"],
  },
  {
    name: "Biznes",
    price: "649",
    desc: "Dla rozwijających się firm i spółek",
    featured: true,
    items: [
      "Do 100 dokumentów / miesiąc",
      "Pełna księgowość",
      "Deklaracje VAT + JPK",
      "Obsługa do 5 pracowników",
