const opinie = [
  {
    name: "Marek Kowalczyk",
    role: "Właściciel, Kowalczyk Transport Sp. z o.o.",
    photo: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?auto=format&fit=crop&w=80&q=80",
    text: "KontoPlus obsługuje naszą spółkę od 4 lat. Profesjonalizm na najwyższym poziomie — terminowo, rzetelnie, z pełnym zrozumieniem specyfiki branży transportowej. Polecam bez zastrzeżeń.",
    rating: 5,
  },
  {
    name: "Anna Wiśniewska",
    role: "CEO, TechFlow Solutions",
    photo: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=80&q=80",
    text: "Jako startup technologiczny potrzebowaliśmy biura, które rozumie nasz model biznesowy. KontoPlus doradzili nam optymalną strukturę podatkową i zaoszczędzili nam kilkadziesiąt tysięcy złotych rocznie.",
    rating: 5,
  },
  {
    name: "Piotr Jabłoński",
    role: "Właściciel, Piekarnia Jabłońscy",
    photo: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=80&q=80",
    text: "Przeszedłem do KontoPlus po złych doświadczeniach z poprzednim biurem. Różnica jest kolosalna — mam zawsze aktualny wgląd w finanse firmy i wsparcie kiedy go potrzebuję.",
    rating: 5,
  },
  {
    name: "Karolina Dąbrowska",
    role: "Dyrektor Finansowy, MedCare Sp. z o.o.",
    photo: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&w=80&q=80",
    text: "Obsługa kadrowa dla 45 pracowników bez żadnej wpadki od 2 lat. Dedykowany opiekun zna naszą firmę na wylot. Aplikacja do wymiany dokumentów jest bardzo wygodna.",
    rating: 5,
  },
];

const stats = [
  { value: 320, suffix: "+", label: "Obsługiwanych firm" },
  { value: 15, suffix: " lat", label: "Doświadczenia" },
  { value: 99, suffix: "%", label: "Terminowości deklaracji" },
  { value: 4800, suffix: "+", label: "Rozliczonych deklaracji" },
];
---

<Layout>
  <!-- ===== NAWIGACJA ===== -->
  <header
    id="nav"
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  >
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex items-center justify-between h-18 py-4">
        <!-- Logo -->
        <a href="#" class="flex items-center gap-2 group">
          <div class="w-9 h-9 rounded-lg bg-teal flex items-center justify-center text-white font-black text-lg leading-none select-none group-hover:scale-105 transition-transform duration-200">K+</div>
          <span class="font-bold text-xl tracking-tight text-graphite">Konto<span class="text-teal">Plus</span></span>
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-8">
          {navLinks.map((l) => (
            <a
              href={l.href}
              class="text-sm font-500 text-graphite hover:text-teal transition-colors duration-200 relative after:absolute after:bottom-[-3px] after:left-0 after:w-0 after:h-[2px] after:bg-teal after:transition-all after:duration-300 hover:after:w-full"
            >
              {l.label}
            </a>
          ))}
          <a
            href="#kontakt"
            class="btn-primary ml-2 bg-teal text-white text-sm font-600 px-5 py-2.5 rounded-lg"
          >
            Bezpłatna wycena
          </a>
        </nav>

        <!-- Burger -->
        <button
          id="burger"
          class="md:hidden flex flex-col gap-1.5 p-2 rounded-lg hover:bg-mint transition-colors"
          aria-label="Menu"
        >
          <span class="w-6 h-0.5 bg-graphite rounded-full block"></span>
          <span class="w-6 h-0.5 bg-graphite rounded-full block"></span>
          <span class="w-4 h-0.5 bg-graphite rounded-full block self-end"></span>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden bg-white border-t border-border shadow-lg"
    >
      <div class="px-6 py-4 flex flex-col gap-4">
        {navLinks.map((l) => (
          <a href={l.href} class="text-graphite font-500 hover:text-teal transition-colors py-1">
            {l.label}
          </a>
        ))}
        <a
          href="#kontakt"
          class="btn-primary bg-teal text-white text-sm font-600 px-5 py-3 rounded-lg text-center mt-2"
        >
          Bezpłatna wycena
        </a>
      </div>
    </div>
  </header>

  <!-- ===== HERO ===== -->
  <section
    id="hero"
    class="relative min-h-screen flex items-center bg-graphite overflow-hidden"
  >
    <!-- Background image -->
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&w=1200&q=80"
        alt=""
        class="w-full h-full object-cover opacity-20"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-graphite via-graphite/95 to-teal/40"></div>
    </div>

    <!-- Decorative elements -->
    <div class="absolute top-20 right-0 w-96 h-96 rounded-full bg-teal/10 blur-3xl z-0"></div>
    <div class="absolute bottom-10 left-10 w-64 h-64 rounded-full bg-teal/8 blur-2xl z-0"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 py-32 pt-40">
      <div class="max-w-3xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-teal/20 border border-teal/30 rounded-full px-4 py-1.5 mb-8">
          <span class="w-2 h-2 rounded-full bg-teal-light animate-pulse"></span>
          <span class="text-sm font-500 text-mint">Biuro rachunkowe z certyfikatem MF</span>
        </div>

        <h1 class="text-5xl lg:text-7xl font-800 text-white leading-tight tracking-tight mb-6">
          Twoje finanse<br />
          <span class="text-teal-light">w dobrych rękach.</span>
        </h1>

        <p class="text-lg lg:text-xl text-slate-300 font-400 leading-relaxed mb-10 max-w-2xl">
          KontoPlus to profesjonalne biuro rachunkowe dla firm, które cenią rzetelność,
          terminowość i spokój ducha. Obsługujemy ponad 320 firm w Polsce.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mb-16">
          <a
            href="#kontakt"
            class="btn-primary bg-teal text-white font-700 text-base px-8 py-4 rounded-xl inline-flex items-center justify-center gap-2"
          >
            Bezpłatna wycena
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href="#uslugi"
            class="btn-outline border-2 border-white/30 text-white font-600 text-base px-8 py-4 rounded-xl hover:bg-white/10 inline-flex items-center justify-center gap-2"
          >
            Poznaj nasze usługi
          </a>
        </div>

        <!-- Trust signals -->
        <div class="flex flex-wrap gap-6 items-center">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-teal-light">
              <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-slate-300">Licencjonowani doradcy podatkowi</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-teal-light">
              <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-slate-300">Ubezpieczenie OC biura</span>
          </div>
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-teal-light">
              <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm13.36-1.814a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-slate-300">Bezpłatna pierwsza konsultacja</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 animate-bounce">
      <span class="text-xs text-slate-400 uppercase tracking-widest">Przewiń</span>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-teal-light">
        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
      </svg>
    </div>
  </section>

  <!-- ===== STATS BAR ===== -->
  <section class="bg-teal py-12">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center text-white">
        {stats.map((s, i) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <div class="text-4xl lg:text-5xl font-800 mb-1">
